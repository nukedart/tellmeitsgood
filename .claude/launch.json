{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Vercel Dev (full stack)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vercel", "dev", "--listen", "3000"],
      "port": 3000
    },
    {
      "name": "Static file server (HTML only)",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8080"],
      "port": 8080
    }
  ]
}
